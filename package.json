{
	"name": "@liiift-studio/hoverboldly",
	"version": "1.1.9",
	"description": "Variable font weight hover and bold interactions without layout shift \u2014 wght increase with automatic wdth/tracking compensation",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "tsc --noEmit",
		"prepublishOnly": "npm run test:run && npm run build"
	},
	"peerDependencies": {
		"react": ">=17",
		"react-dom": ">=17"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"happy-dom": "^12.0.0",
		"next": "16.2.2",
		"react": "^19.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0"
	},
	"keywords": [
		"typography",
		"web-typography",
		"frontend",
		"liiift-studio",
		"variable-font",
		"font-variation-settings",
		"hover",
		"bold",
		"bold-hover",
		"weight-hover",
		"no-layout-shift",
		"cls",
		"interaction",
		"wght",
		"letter-spacing",
		"canvas",
		"zero-dependencies",
		"react",
		"typescript",
		"css"
	],
	"author": "Quinn Keaveney <quinn@liiift.studio>",
	"license": "MIT",
	"homepage": "https://hoverboldly.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/HoverBoldly.git"
	},
	"bugs": {
		"url": "https://github.com/Liiift-Studio/HoverBoldly/issues"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	}
}
